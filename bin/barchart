#!/usr/bin/perl
# Print a barchart of duplicated lines in a file showing relative frequencies. Usage: barchart file.txt

use strict;
use warnings;

if ( !scalar @ARGV ) {
    die <<MSG;
Missing Argument.
    usage: barchart file.txt
MSG
}

open(my $fh, '<', $ARGV[0]) or die "Can't open $ARGV[0]: $!";

my $max    = 0;
my %struct = ();

# Generate structure
while ( <$fh> ) {
    my $word = $_;

    $struct{$word} += 1;
    if ($max < $struct{ $word }) {
        $max = $struct{ $word };
    }
}

for my $key ( keys %struct ) {
    my $stars = ( $struct{$key} / $max ) * 10;
    printf( "%10s| %s", '0' x $stars, $key );
}
